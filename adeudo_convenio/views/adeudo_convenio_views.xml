<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Vista Tree (Lista) Actualizada -->
    <record id="view_tree_adeudo_convenio" model="ir.ui.view">
        <field name="name">adeudo.convenio.tree</field>
        <field name="model">adeudo.convenio</field>
        <field name="arch" type="xml">
            <tree string="Convenios de Adeudo">
                <field name="name"/>
                <field name="employee_id"/>
                <field name="job_id"/> <!-- Nuevo en lista -->
                <field name="estatus_colaborador" widget="badge" decoration-success="estatus_colaborador == 'activo'" decoration-danger="estatus_colaborador == 'baja'"/> <!-- Nuevo en lista -->
                <field name="motivo"/>
                <field name="monto_total" sum="Total Adeudado"/>
                <field name="monto_pendiente" sum="Total Pendiente"/>
                <field name="progreso_pago_porcentaje" widget="progressbar" string="Progreso"/>
                <field name="estado"/>
            </tree>
        </field>
    </record>

    <!-- Vista Form Actualizada -->
    <record id="view_form_adeudo_convenio" model="ir.ui.view">
        <field name="name">adeudo.convenio.form.v16</field>
        <field name="model">adeudo.convenio</field>
        <field name="arch" type="xml">
            <form string="Convenio de Adeudo">
                <header>
                    <field name="estado" widget="statusbar" statusbar_visible="borrador,en_proceso,cerrado"/>
                    <button name="action_confirmar" type="object" string="Confirmar" class="btn-primary" invisible="estado != 'borrador'"/>
                    <button name="action_print_report" type="object" string="Imprimir" class="oe_highlight" icon="fa-print"/>
                    <button name="action_resetear_borrador" type="object" string="Resetear" invisible="estado == 'borrador'"/>
                </header>
                
                <sheet>
                    <div class="oe_title">
                        <h1><field name="name" readonly="1"/></h1>
                    </div>
                    
                    <group>
                        <group string="Información del Colaborador">
                            <field name="employee_id"/>
                            <field name="job_id"/> <!-- Puesto justo debajo del empleado -->
                            <field name="estatus_colaborador" widget="radio" options="{'horizontal': true}"/> <!-- Estatus -->
                            <field name="numero_empleado"/>
                            <field name="responsable_id"/>
                            <field name="analista_id"/>
                        </group>
                        <group string="Detalles del Adeudo">
                            <field name="motivo"/>
                            <field name="distrito"/>
                            <field name="monto_total"/>
                            <field name="currency_id" invisible="1"/>
                            <field name="fecha_incidencia"/>
                            <field name="fecha_inicio"/>
                        </group>
                    </group>
                    
                    <group string="Cálculo de Pagos" col="4">
                        <field name="numero_pagos_manual"/>
                        <field name="monto_descuento_quincenal"/>
                        <field name="numero_pagos_sugerido" readonly="1"/>
                    </group>

                    <group string="Progreso">
                        <field name="progreso_pago_porcentaje" widget="progressbar"/>
                        <field name="total_abonado"/>
                        <field name="monto_pendiente"/>
                    </group>

                    <notebook>
                        <page string="Plan de Pagos" name="plan_pagos">
                            <field name="linea_pago_ids">
                                <tree editable="bottom" create="0" delete="0">
                                    <field name="numero_pago" readonly="1"/>
                                    <field name="fecha_pago" readonly="1"/>
                                    <field name="monto" readonly="1"/>
                                    <field name="estado_pago"/>
                                    <field name="comentario"/>
                                </tree>
                            </field>
                        </page>
                        <page string="Documentos" name="documentos">
                            <group>
                                <field name="convenio_generado" filename="convenio_filename"/>
                                <field name="convenio_filename" invisible="1"/>
                                <field name="convenio_firmado" filename="convenio_firmado_filename"/>
                                <field name="convenio_firmado_filename" invisible="1"/>
                                <field name="estado_convenio_firma" widget="radio" options="{'horizontal': true}"/>
                            </group>
                        </page>
                        <page string="Notas" name="notas">
                            <field name="notas"/>
                        </page>
                    </notebook>
                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids"/>
                    <field name="message_ids"/>
                </div>
            </form>
        </field>
    </record>
</odoo>
